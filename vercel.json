{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/patients",
      "destination": "/api/wix-data.js?collection=QuoteSubmissions"
    },
    {
      "source": "/api/inquiries",
      "destination": "/api/wix-data.js?collection=ContactMessages"
    },
    {
      "source": "/api/procedures",
      "destination": "/api/wix-data.js?collection=Procedures"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/wix-data.js?collection=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}